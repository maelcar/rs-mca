      "D_J": "(M-rho)^2-M(kappa-1)",
      "J_K": "(N-t)^2-N(kappa-1)"
    },
    "parameters": [
      "N=R+kappa",
      "0<=t<R",
      "1<=direction_d<=R",
      "M=N-direction_d",
      "rho=min(t,M)",
      "deficiency_delta=2t-R",
